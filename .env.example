# ── LLM ──────────────────────────────────────────────────────────────────────
# Get a key at openrouter.ai — same models, pay-as-you-go
OPENROUTER_API_KEY=sk-or-v1-your-key-here
COMPASS_MODEL=anthropic/claude-sonnet-4-6

# ── Langfuse (self-hosted) ────────────────────────────────────────────────────
# Run: docker compose up -d
# UI at http://localhost:3000 — create a project and copy the keys
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_PATH=/Users/your-username/Documents/compass-vault

# ── RAG ───────────────────────────────────────────────────────────────────────
CHROMA_PATH=~/.compass/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── HiTL ──────────────────────────────────────────────────────────────────────
HITL_STATE_DB=~/.compass/hitl.db
HITL_TIMEOUT_HOURS=4

# ── Pipeline settings ─────────────────────────────────────────────────────────
MAX_JOBS_PER_RUN=50
SCORE_THRESHOLD=3.5
MAX_CONCURRENT_JOBS=5

# ── ATS scraper targets ───────────────────────────────────────────────────────
# Comma-separated Greenhouse board tokens (find in company career page URL)
GREENHOUSE_BOARDS=databricks,scale-ai,langchain,anthropic,sierra-hq,glean

# Comma-separated Lever company slugs
LEVER_COMPANIES=databricks,scale-ai,anthropic

# Comma-separated Ashby board names
ASHBY_BOARDS=langchain,posthog,linear,ramp,vercel
