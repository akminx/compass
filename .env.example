# ── LLM ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Per-node model routing — leave defaults unless you have a specific reason
EXTRACT_MODEL=google/gemini-2.5-flash
SCORE_MODEL=google/gemini-2.5-flash
REFLECT_MODEL=anthropic/claude-sonnet-4-6
TAILOR_MODEL=anthropic/claude-sonnet-4-6
ASSESSOR_MODEL=anthropic/claude-sonnet-4-6
COMPASS_MODEL=anthropic/claude-sonnet-4-6  # legacy fallback

# ── Langfuse (self-hosted) ───────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── Vaults ───────────────────────────────────────────────────────────────────
# Replace with your local paths. Tilde is expanded automatically by Compass.
VAULT_PATH=~/Documents/compass-vault
LEARNING_VAULT_PATH=~/Documents/learning-vault

# ── RAG ──────────────────────────────────────────────────────────────────────
CHROMA_PATH=~/.compass/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── HiTL ─────────────────────────────────────────────────────────────────────
HITL_STATE_DB=~/.compass/hitl.db
HITL_CHECKPOINT_DB=~/.compass/checkpoints.db
HITL_TIMEOUT_HOURS=4

# ── Pipeline ─────────────────────────────────────────────────────────────────
MAX_JOBS_PER_RUN=50
SCORE_THRESHOLD=3.5
MAX_CONCURRENT_JOBS=5

# ── ATS targets ──────────────────────────────────────────────────────────────
# Comma-separated list of ATS board slugs to scrape — replace with your targets.
GREENHOUSE_BOARDS=acme,exampleco,democorp
LEVER_COMPANIES=acme
ASHBY_BOARDS=acme,exampleco,democorp
